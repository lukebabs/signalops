{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.syncratic.local/signalops/events/signal.v1.schema.json",
  "title": "Signal",
  "description": "Algorithmic detection result emitted by processing workers.",
  "type": "object",
  "additionalProperties": false,
  "required": ["signal_id", "tenant_id", "source_id", "source_domain", "source_adapter", "ingestion_mode", "dataset", "event_ids", "artifact_ids", "signal_type", "detector_id", "detector_version", "model_version", "timestamp", "observation_time", "effective_time", "processing_time", "window_start", "window_end", "confidence", "severity", "entities", "supporting_metrics", "graph_targets", "semantic_evidence", "evidence", "recommendation", "correlation_id"],
  "properties": {
    "signal_id": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "tenant_id": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "source_id": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "app_id": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string", "default": "console"},
    "domain": {"$ref": "common.defs.v1.schema.json#/$defs/source_domain"},
    "use_case": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string", "default": "general"},
    "source_domain": {"$ref": "common.defs.v1.schema.json#/$defs/source_domain"},
    "source_adapter": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "ingestion_mode": {"$ref": "common.defs.v1.schema.json#/$defs/ingestion_mode"},
    "dataset": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "event_ids": {"type": "array", "minItems": 1, "items": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"}},
    "artifact_ids": {"type": "array", "items": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"}},
    "signal_type": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "detector_id": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "detector_version": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "model_version": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "timestamp": {"$ref": "common.defs.v1.schema.json#/$defs/timestamp"},
    "observation_time": {"$ref": "common.defs.v1.schema.json#/$defs/timestamp"},
    "effective_time": {"$ref": "common.defs.v1.schema.json#/$defs/timestamp"},
    "processing_time": {"$ref": "common.defs.v1.schema.json#/$defs/timestamp"},
    "window_start": {"$ref": "common.defs.v1.schema.json#/$defs/timestamp"},
    "window_end": {"$ref": "common.defs.v1.schema.json#/$defs/timestamp"},
    "confidence": {"$ref": "common.defs.v1.schema.json#/$defs/confidence"},
    "severity": {"type": "string", "enum": ["info", "low", "medium", "high", "critical"]},
    "entities": {"type": "array", "items": {"$ref": "common.defs.v1.schema.json#/$defs/entity_ref"}},
    "supporting_metrics": {"type": "object"},
    "graph_targets": {"type": "array", "items": {"type": "object"}},
    "semantic_evidence": {"type": "array", "items": {"type": "object"}},
    "evidence": {"type": "array", "items": {"$ref": "common.defs.v1.schema.json#/$defs/evidence_ref"}},
    "recommendation": {"type": ["object", "null"]},
    "correlation_id": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "trace_id": {"type": "string"},
    "causation_id": {"type": "string"},
    "replay_job_id": {"type": "string"}
  }
}
