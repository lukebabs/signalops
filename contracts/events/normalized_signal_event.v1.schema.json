{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.syncratic.local/signalops/events/normalized_signal_event.v1.schema.json",
  "title": "NormalizedSignalEvent",
  "description": "Validated and normalized SignalOps event envelope published for processing workers.",
  "type": "object",
  "additionalProperties": false,
  "required": ["tenant_id", "source_id", "source_domain", "source_adapter", "ingestion_mode", "dataset", "event_id", "event_type", "schema_id", "schema_version", "observation_time", "effective_time", "processing_time", "occurred_at", "observed_at", "normalized_payload", "entities", "confidence", "metadata", "evidence", "correlation_id", "idempotency_key"],
  "properties": {
    "tenant_id": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "source_id": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "source_domain": {"$ref": "common.defs.v1.schema.json#/$defs/source_domain"},
    "source_adapter": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "ingestion_mode": {"$ref": "common.defs.v1.schema.json#/$defs/ingestion_mode"},
    "dataset": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "event_id": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "event_type": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "schema_id": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "schema_version": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "observation_time": {"$ref": "common.defs.v1.schema.json#/$defs/timestamp"},
    "effective_time": {"$ref": "common.defs.v1.schema.json#/$defs/timestamp"},
    "processing_time": {"$ref": "common.defs.v1.schema.json#/$defs/timestamp"},
    "occurred_at": {"$ref": "common.defs.v1.schema.json#/$defs/timestamp"},
    "observed_at": {"$ref": "common.defs.v1.schema.json#/$defs/timestamp"},
    "normalized_payload": {"type": "object"},
    "entities": {"type": "array", "items": {"$ref": "common.defs.v1.schema.json#/$defs/entity_ref"}},
    "confidence": {"$ref": "common.defs.v1.schema.json#/$defs/confidence"},
    "metadata": {"type": "object"},
    "evidence": {"type": "array", "items": {"$ref": "common.defs.v1.schema.json#/$defs/evidence_ref"}},
    "correlation_id": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "idempotency_key": {"$ref": "common.defs.v1.schema.json#/$defs/non_empty_string"},
    "trace_id": {"type": "string"},
    "causation_id": {"type": "string"},
    "replay_job_id": {"type": "string"}
  }
}
