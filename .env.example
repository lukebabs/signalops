# SignalOps local development environment example
# Copy to .env for local Compose/profile runs and replace placeholder secrets.
# Do not commit real API keys or production credentials.

# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
SIGNALOPS_ENV=local
SIGNALOPS_HTTP_ADDR=:8080

# Broker provider is currently Redpanda/Kafka-compatible.
SIGNALOPS_BROKER_PROVIDER=redpanda
SIGNALOPS_BROKER_BROKERS=redpanda:9092

# Host-side broker address for one-off local integration tests run outside Compose.
# Example: SIGNALOPS_BROKER_BROKERS=localhost:19092

# -----------------------------------------------------------------------------
# Identity provider / OIDC
# -----------------------------------------------------------------------------
# Auth enforcement is implemented in the gateway and is enabled when
# SIGNALOPS_AUTH_ENABLED=true. Keep false until the frontend login/token gate lands.
SIGNALOPS_AUTH_ENABLED=false
SIGNALOPS_AUTH_ISSUER=https://auth.syncratic.co/realms/syncratic
SIGNALOPS_AUTH_REALM=syncratic
SIGNALOPS_AUTH_JWKS_URL=https://auth.syncratic.co/realms/syncratic/protocol/openid-connect/certs
SIGNALOPS_AUTH_AUDIENCE=signalops-api
SIGNALOPS_AUTH_CLIENT_ID=signalops-web

# Frontend OIDC values. Vite exposes only VITE_* variables to browser code.
VITE_SIGNALOPS_AUTH_ENABLED=false
VITE_SIGNALOPS_AUTH_ISSUER=https://auth.syncratic.co/realms/syncratic
VITE_SIGNALOPS_AUTH_REALM=syncratic
VITE_SIGNALOPS_AUTH_CLIENT_ID=signalops-web

# -----------------------------------------------------------------------------
# Public edge / Syncratic Traefik
# -----------------------------------------------------------------------------
# The parent Syncratic core Traefik service owns Let's Encrypt and TLS
# termination. Use compose.traefik.yaml to attach SignalOps web to that edge.
SIGNALOPS_PUBLIC_HOST=signalops.syncratic.io
TRAEFIK_NETWORK=syncratic-core_syncratic_net
COMPOSE_FILE=compose.yaml:compose.traefik.yaml

# -----------------------------------------------------------------------------
# PostgreSQL storage
# -----------------------------------------------------------------------------
# Compose services use the container DNS name postgres. Host-side tests can use
# localhost:15432 instead.
SIGNALOPS_DATABASE_URL=postgres://signalops:signalops@postgres:5432/signalops?sslmode=disable
# Optional separate TimescaleDB DSN for replayable temporal ledgers. Leave empty to use SIGNALOPS_DATABASE_URL.
SIGNALOPS_TEMPORAL_DATABASE_URL=postgres://signalops:signalops@timescaledb:5432/signalops_temporal?sslmode=disable
SIGNALOPS_MIGRATION_DIR=/workspace/migrations

# Optional integration-test toggles. Leave unset for normal runs.
SIGNALOPS_BROKER_INTEGRATION=0
SIGNALOPS_POSTGRES_INTEGRATION=0

# -----------------------------------------------------------------------------
# Redpanda topic bootstrap
# -----------------------------------------------------------------------------
SIGNALOPS_BROKERS=redpanda:9092
SIGNALOPS_TOPIC_PARTITIONS=3
SIGNALOPS_TOPIC_REPLICAS=1

# -----------------------------------------------------------------------------
# Massive market-data adapter
# -----------------------------------------------------------------------------
# Preferred key name. MASSIVE_API_KEY and API_KEY are supported fallback names.
SIGNALOPS_MASSIVE_API_KEY=replace-with-massive-api-key
MASSIVE_API_KEY=
API_KEY=

# Optional provider endpoint override for tests or proxies. Leave blank for live Massive.
SIGNALOPS_MASSIVE_BASE_URL=

SIGNALOPS_MASSIVE_TENANT_ID=tenant-local
SIGNALOPS_MASSIVE_SOURCE_ID=src-massive
SIGNALOPS_MASSIVE_DATASETS=equity,options

# Optional YYYY-MM-DD. Blank defaults to previous UTC day.
SIGNALOPS_MASSIVE_OBSERVATION_DATE=

# Universe and provider request controls.
SIGNALOPS_MASSIVE_MAX_COMPANIES=50
SIGNALOPS_MASSIVE_OPTIONS_LIMIT=100
SIGNALOPS_MASSIVE_REQUEST_DELAY=250ms
SIGNALOPS_MASSIVE_MAX_RETRIES=1
SIGNALOPS_MASSIVE_RETRY_BACKOFF=1s

# Hard run budgets. 0 means no explicit cap.
SIGNALOPS_MASSIVE_MAX_PROVIDER_REQUESTS=0
SIGNALOPS_MASSIVE_MAX_EVENTS_BUILT=0
SIGNALOPS_MASSIVE_MAX_EVENTS_PUBLISHED=0

# Keep dry-run true until you intentionally publish raw events.
SIGNALOPS_MASSIVE_DRY_RUN=true
SIGNALOPS_MASSIVE_CONTINUE_ON_ERROR=true

# Scheduler controls for the massive-schedule profile.
SIGNALOPS_MASSIVE_SCHEDULE_INTERVAL=24h
SIGNALOPS_MASSIVE_SCHEDULE_MAX_RUNS=0
SIGNALOPS_MASSIVE_SCHEDULE_RUN_IMMEDIATELY=true
SIGNALOPS_MASSIVE_SCHEDULE_CONTINUE_ON_ERROR=true

# Governed post-close workflow. The timer installer supplies the write
# acknowledgement; do not add real credentials or acknowledgement values here.
MARKETOPS_DAILY_TIMEZONE=America/New_York
MARKETOPS_DAILY_MIN_EQUITY_SYMBOLS=45
MARKETOPS_DAILY_NORMALIZATION_TIMEOUT_SECONDS=300
MARKETOPS_DAILY_NORMALIZATION_POLL_SECONDS=10
MARKETOPS_DAILY_ACTOR=systemd-postclose
MARKETOPS_DAILY_SKIP_COMPLETE_EQUITY=true
# Explicit provider-supported cohort. Equity still attempts all 50 assets so
# unsupported listings remain visible in the scheduled pull report.
MARKETOPS_DAILY_OPTION_SYMBOLS=AAPL,GOOGL,MSFT,AMZN,TSM,SPCX,AVGO,TSLA,META,MU,BRK.B,LLY,JPM,AMD,WMT,ASML,V,JNJ,INTC,XOM,TCEHY,MA,AMAT,ABBV,CSCO,CAT,LRCX,BAC,COST,ORCL,GE,UNH,KO,MS,HD,PG,ARM,HSBC,CVX,NFLX,PLTR,MRK,GS,GEV,NVDA

# -----------------------------------------------------------------------------
# Python detector worker
# -----------------------------------------------------------------------------
SIGNALOPS_WORKER_INPUT_TOPIC=signalops.local.normalized.v1
SIGNALOPS_WORKER_RETRY_TOPIC=signalops.local.retry.algorithm.v1
SIGNALOPS_WORKER_DLQ_TOPIC=signalops.local.dlq.algorithm.v1
SIGNALOPS_WORKER_SIGNAL_TOPIC=signalops.local.signal.v1
SIGNALOPS_WORKER_GROUP_ID=signalops.normalized-worker.v1
SIGNALOPS_WORKER_POLL_TIMEOUT_SECONDS=1
SIGNALOPS_WORKER_MAX_MESSAGES=0
SIGNALOPS_WORKER_DETECTOR_ID=marketops.dsm.taxonomy_v1
SIGNALOPS_WORKER_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Retry replayer
# -----------------------------------------------------------------------------
SIGNALOPS_RETRY_REPLAY_RAW_TOPIC=signalops.local.raw.v1
SIGNALOPS_RETRY_REPLAY_INPUT_TOPIC=signalops.local.retry.algorithm.v1
SIGNALOPS_RETRY_REPLAY_DLQ_TOPIC=signalops.local.dlq.algorithm.v1
SIGNALOPS_RETRY_REPLAY_GROUP_ID=signalops.retry-replayer.v1
SIGNALOPS_RETRY_REPLAY_POLL_TIMEOUT_SECONDS=1
SIGNALOPS_RETRY_REPLAY_MAX_MESSAGES=0
SIGNALOPS_RETRY_REPLAY_MAX_ATTEMPTS=3
SIGNALOPS_RETRY_REPLAY_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Replay worker
# -----------------------------------------------------------------------------
SIGNALOPS_REPLAY_WORKER_ID=signalops-replay-worker
SIGNALOPS_REPLAY_ONESHOT=false
SIGNALOPS_REPLAY_MAX_RECORDS=50
SIGNALOPS_REPLAY_BATCH_SIZE=50
SIGNALOPS_REPLAY_PUBLISH_MAX_ATTEMPTS=3
SIGNALOPS_REPLAY_POLL_INTERVAL=5s

# -----------------------------------------------------------------------------
# Frontend development
# -----------------------------------------------------------------------------
# For Vite dev, leave VITE_SIGNALOPS_API_BASE_URL unset/blank so the app uses
# same-origin and vite.config.ts proxies /healthz, /readyz, and /v1 to the gateway.
# Set an absolute API base only when that deployment path supports CORS.
VITE_SIGNALOPS_API_BASE_URL=
SIGNALOPS_GATEWAY_URL=http://localhost:18000
# -----------------------------------------------------------------------------
# Syncratic user facade API
# -----------------------------------------------------------------------------
# Contract: docs/syncratic_user_api_v1.yaml. The OpenAPI contract requires
# Bearer JWT auth; username/password are only inputs to the configured token flow.
SYNCRATIC_API_BASE_URL=https://portal.syncratic.co
# Use api_key when SYNCRATIC_CLIENT_SECRET is accepted directly by the user facade.
# Use token when a separate bearer-token endpoint/grant is required.
SYNCRATIC_AUTH_MODE=api_key
SYNCRATIC_AUTH_ISSUER=https://auth.syncratic.co/realms/syncratic
SYNCRATIC_TOKEN_URL=https://auth.syncratic.co/realms/syncratic/protocol/openid-connect/token
SYNCRATIC_TOKEN_GRANT=password
SYNCRATIC_TOKEN_AUDIENCE=
SYNCRATIC_CLIENT_ID=
# Syncratic API key used by the configured non-browser token flow.
SYNCRATIC_CLIENT_SECRET=
SYNCRATIC_USERNAME=
SYNCRATIC_PASSWORD=
