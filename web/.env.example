# Browser-facing API base URL. Leave UNSET in dev — the Vite dev proxy forwards
# /healthz, /readyz, /v1 to the gateway (see vite.config.ts), so the app calls
# same-origin. Set an absolute URL only for production/gateway-served
# deployments where the gateway emits CORS headers (not implemented today).
# VITE_SIGNALOPS_API_BASE_URL=http://localhost:18000

# Server-side proxy target used by vite.config.ts. Defaults to the local gateway.
SIGNALOPS_GATEWAY_URL=http://localhost:18000
