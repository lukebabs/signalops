# Browser-facing API base URL. Leave UNSET in dev — the Vite dev proxy forwards
# /healthz, /readyz, /v1 to the gateway (see vite.config.ts), so the app calls
# same-origin. Set an absolute URL only for production/gateway-served
# deployments where the gateway emits CORS headers (not implemented today).
# VITE_SIGNALOPS_API_BASE_URL=http://localhost:18000

# Server-side proxy target used by vite.config.ts. Defaults to the local gateway.
SIGNALOPS_GATEWAY_URL=http://localhost:18000

# Frontend OIDC (Syncratic IdP). Auth is OFF by default. Set
# VITE_SIGNALOPS_AUTH_ENABLED=true to switch the SPA to IdP login + Bearer
# token API calls. These are read by Vite at build time; for the containerized
# build they are passed as compose build args (see compose.yaml + Dockerfile).
VITE_SIGNALOPS_AUTH_ENABLED=false
VITE_SIGNALOPS_AUTH_ISSUER=https://auth.syncratic.co/realms/syncratic
VITE_SIGNALOPS_AUTH_REALM=syncratic
VITE_SIGNALOPS_AUTH_CLIENT_ID=signalops-web
VITE_SIGNALOPS_AUTH_AUDIENCE=signalops-api
